import socket
from redis import Redis
from config import REDIS_HOST, REDIS_PASSWORD

def test_connection(host, port=6379, use_ssl=False, password=None):
    # First test basic TCP connection
    try:
        print(f"\nTesting TCP connection to {host}:{port}...")
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        sock.connect((host, port))
        print("✓ TCP Connection successful")
        sock.close()
    except Exception as e:
        print(f"✗ TCP Connection failed: {e}")
        return

    # Test Redis connection
    try:
        print("\nTesting Redis connection...")
        r = Redis(
            host=host,
            port=port,
            password=password,
            ssl=use_ssl,
            socket_connect_timeout=5,
            decode_responses=True
        )
        print("Redis ping response:", r.ping())
        print("✓ Redis connection successful")
        return r
    except Exception as e:
        print(f"✗ Redis connection failed: {e}")
        return None

if __name__ == "__main__":
    host = REDIS_HOST or 'localhost'
    password = REDIS_PASSWORD if REDIS_PASSWORD else None
    
    print(f"Testing Redis connection to: {host}")
    print(f"Using password: {'Yes' if password else 'No'}")
    
    # Test without SSL first
    print("\n=== Testing without SSL ===")
    conn = test_connection(host, password=password, use_ssl=False)
    
    if not conn:
        # If that fails, try with SSL
        print("\n=== Testing with SSL ===")
        test_connection(host, password=password, use_ssl=True)